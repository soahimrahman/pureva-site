<%- include('partials/shell-start') %>

  <div class="admin-header">
    <div class="admin-breadcrumb"><a href="/admin" style="color:inherit">Dashboard</a> / <%= config.label %></div>
    <h1><%= config.label %></h1>
  </div>

  <div class="admin-list-head">
    <span style="color: var(--ink-soft); font-size: 0.9rem;"><%= items.length %> item<%= items.length === 1 ? '' : 's' %></span>
    <a href="/admin/<%= sectionKey %>/new" class="btn btn-outline btn-sm">+ Add <%= config.singular %></a>
  </div>

  <% if (items.length === 0) { %>
    <div class="admin-empty">No <%= config.label.toLowerCase() %> yet. Click "Add <%= config.singular %>" to create the first one.</div>
  <% } else { %>
    <table class="admin-table">
      <thead>
        <tr><th><%= config.singular %></th><th></th></tr>
      </thead>
      <tbody>
        <% items.forEach(function(item) { %>
          <tr>
            <td>
              <div class="item-title"><%= config.listTitle(item) %></div>
              <% if (config.listSubtitle(item)) { %><div class="item-sub"><%= config.listSubtitle(item) %></div><% } %>
            </td>
            <td>
              <div class="row-actions">
                <a href="/admin/<%= sectionKey %>/<%= item.id %>/edit" class="btn btn-ghost btn-sm">Edit</a>
                <form action="/admin/<%= sectionKey %>/<%= item.id %>/delete" method="POST" class="delete-form" onsubmit="return confirm('Delete this <%= config.singular.toLowerCase() %>? This cannot be undone.');">
                  <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>

<%- include('partials/shell-end') %>
