# Copy this file to .env and fill in real values before running the site.

# Port the server listens on. Most hosts set this automatically — only
# change it for local development if 3000 is already in use.
PORT=3000

# A long, random string used to sign admin login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never reuse the example below in a real deployment.
SESSION_SECRET=change-this-to-a-long-random-string
